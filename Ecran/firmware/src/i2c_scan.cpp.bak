/*
 * I2C Scanner for JC3636W518C — detect touch controller
 * Scans multiple SDA/SCL pin pairs looking for I2C devices.
 */
#include <Arduino.h>
#include <Wire.h>

struct PinPair { int sda; int scl; };

// Common candidate pin pairs for touch on JC3636W518C
static const PinPair pairs[] = {
    {5, 6},   // Most common for this module
    {4, 3},   // Alternative
    {7, 8},   // Alternative
    {1, 2},   // Alternative
    {4, 5},   // Alternative
    {6, 7},   // Alternative
    {3, 2},   // Alternative
    {8, 4},   // Alternative
    {0, 1},   // Alternative
};
static const int NUM_PAIRS = sizeof(pairs) / sizeof(pairs[0]);

void setup() {
    Serial.begin(115200);
    delay(2000);
    Serial.println("\n=== I2C Scanner for JC3636W518C Touch ===\n");

    for (int p = 0; p < NUM_PAIRS; p++) {
        int sda = pairs[p].sda;
        int scl = pairs[p].scl;

        Serial.printf("--- Scanning SDA=%d, SCL=%d ---\n", sda, scl);

        Wire.begin(sda, scl);
        delay(50);

        int found = 0;
        for (uint8_t addr = 1; addr < 127; addr++) {
            Wire.beginTransmission(addr);
            uint8_t err = Wire.endTransmission();
            if (err == 0) {
                Serial.printf("  FOUND device at 0x%02X", addr);
                if (addr == 0x15) Serial.print("  <-- CST816S / CST820");
                if (addr == 0x38) Serial.print("  <-- FT5x06 / FT6336");
                if (addr == 0x5D) Serial.print("  <-- GT911 (addr1)");
                if (addr == 0x14) Serial.print("  <-- GT911 (addr2)");
                if (addr == 0x1A) Serial.print("  <-- CTS328");
                Serial.println();
                found++;
            }
        }

        if (found == 0) {
            Serial.println("  No devices found.");
        }
        Serial.println();

        Wire.end();
        delay(50);
    }

    Serial.println("=== Scan complete ===");
}

void loop() {
    delay(10000);
}
